@model DACN.Models.KhachHang
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="container py-5">
    <h2 class="text-center fw-bold mb-4 text-primary">Thông tin cá nhân</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success">@ViewBag.Message</div>
    }

    <form asp-action="ThongTin" enctype="multipart/form-data" method="post">
        <div class="row g-4">
            <div class="col-md-4 text-center">
                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <img src="@Model.HinhAnh" class="img-thumbnail mb-3" style="max-width: 200px; height:auto;" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ảnh đại diện</label>
                            <input type="file" name="HinhAnhFile" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card shadow-sm border-0 p-3">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Họ tên</label>
                        <input asp-for="HoTen" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số điện thoại</label>
                        <input asp-for="SoDienThoai" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                    <hr />

                    <h5 class="fw-semibold text-primary mb-3">Đổi mật khẩu</h5>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" name="MatKhauCu" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" name="MatKhauMoi" class="form-control" />
                    </div>

                    <div class="d-flex gap-2 flex-wrap mt-3">
                        <button type="submit" class="btn" style="background-color:#ffb703; color:#000; font-weight:bold; min-width:140px;">
                            💾 Lưu thay đổi
                        </button>
                        <a href="/" class="btn btn-outline-secondary px-4">🏠 Quay lại trang chủ</a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    /* Hover card */
    .card:hover {
        transform: translateY(-2px);
        transition: transform 0.2s;
    }

    /* Hover nút */
    .btn:hover {
        opacity: 0.9;
    }

    /* Responsive */
    media (max-width: 576px) {
        .d-flex.flex-wrap

    {
        flex-direction: column;
    }

    .d-flex.flex-wrap .btn {
        width: 100%;
    }

    }
</style>
