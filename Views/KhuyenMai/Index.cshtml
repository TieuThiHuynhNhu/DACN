@model IEnumerable<DACN.Models.KhuyenMai>
@{
    ViewData["Title"] = "Khuyến mãi";
}

<div class="container pt-3 pb-5">
    <h2 class="text-center fw-bold text-primary mb-4">👑 Quản lý khuyến mãi (Admin Dashboard)</h2>

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
        <a asp-action="Them" class="btn btn-success fw-semibold">
            ➕ Thêm khuyến mãi mới
        </a>

        <div class="d-flex gap-2">
            <input type="text" id="searchBox" class="form-control" placeholder="Tìm theo tên/mã KM..." style="width: 250px;">
            <select id="statusFilter" class="form-select" style="width: 150px;">
                <option value="">Tất cả trạng thái</option>
                <option value="DangDienRa">Đang diễn ra</option>
                <option value="SapDienRa">Sắp diễn ra</option>
                <option value="HetHan">Đã hết hạn</option>
            </select>
            <button id="filterButton" class="btn btn-primary fw-semibold">Tìm Kiếm</button>
            <button id="resetButton" class="btn btn-secondary fw-semibold">Reset</button>
        </div>
    </div>

    <div class="table-responsive shadow-lg rounded-3 overflow-hidden">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-primary text-white">
                <tr>
                    <th style="width:100px;">Hình ảnh</th>
                    <th style="width:80px;">Mã KM</th>
                    <th>Tên khuyến mãi</th>
                    <th style="width:130px;">Trạng thái</th>
                    <th style="min-width: 200px;">Phòng áp dụng</th>
                    <th style="width:80px;">Giảm (%)</th>
                    <th style="width:100px;">Ngày bắt đầu</th>
                    <th style="width:100px;">Ngày kết thúc</th>
                    <th style="width:130px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var km in Model)
                {
                    // Logic xác định trạng thái, màu sắc và giá trị lọc
                    var now = DateTime.Now.Date;
                    string statusText, statusClass, statusFilterValue;

                    if (km.NgayKetThuc.Date < now)
                    {
                        statusText = "Đã hết hạn";
                        statusClass = "bg-secondary";
                        statusFilterValue = "HetHan"; // Giá trị lọc JS
                    }
                    else if (km.NgayBatDau.Date > now)
                    {
                        statusText = "Sắp diễn ra";
                        statusClass = "bg-warning text-dark";
                        statusFilterValue = "SapDienRa"; // Giá trị lọc JS
                    }
                    else
                    {
                        statusText = "Đang diễn ra";
                        statusClass = "bg-success";
                        statusFilterValue = "DangDienRa"; // Giá trị lọc JS
                    }

                    <tr data-status="@statusFilterValue">
                        <td>
                            @{
                                var imagePath = string.IsNullOrEmpty(km.HinhAnh) ? "/images/default_km.jpg" : km.HinhAnh;
                            }
                            <img src="@Url.Content(imagePath)" alt="@km.TenKhuyenMai" class="img-thumbnail" style="width:80px;height:60px;object-fit:cover; border-radius: 4px;" />
                        </td>
                        <td class="fw-bold text-info">@km.MaKhuyenMai</td>
                        <td>@km.TenKhuyenMai</td>
                        <td>
                            <span class="badge @statusClass fw-semibold">@statusText</span>
                        </td>
                        <td>
                            @if (km.PhongKhuyenMais != null && km.PhongKhuyenMais.Any())
                            {
                                int count = 0;
                                @foreach (var pk in km.PhongKhuyenMais)
                                {
                                    if (count < 2) // Chỉ hiển thị 2 loại phòng đầu tiên
                                    {
                                        <span class="badge bg-primary me-1 mb-1" style="font-size: 0.75em;">
                                            @pk.Phong?.LoaiPhong
                                        </span>
                                    }
                                    count++;
                                }
                                if (count > 2)
                                {
                                    <span class="badge bg-light text-secondary border" style="font-size: 0.75em;">
                                        +@(count - 2) phòng khác
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-danger small fw-semibold">Chưa áp dụng phòng</span>
                            }
                        </td>

                        <td class="fw-bold text-danger">@km.PhanTramGiam%</td>
                        <td>@km.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@km.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1 flex-wrap">
                                <a asp-action="Sua" asp-route-id="@km.MaKhuyenMai" class="btn btn-warning btn-sm" title="Chỉnh sửa">
                                    <i class="bi bi-pencil-fill"></i> Sửa
                                </a>
                                <a asp-action="Xoa" asp-route-id="@km.MaKhuyenMai" class="btn btn-danger btn-sm" title="Xóa">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    /* ... (CSS cũ giữ nguyên) */
    .text-primary {
        color: #0077b6 !important;
    }

    .table-primary {
        background-color: #0077b6;
        color: white;
    }

    table.table tbody tr:hover {
        background-color: #e0f7fa;
    }

    .img-thumbnail {
        border: 1px solid #ddd;
        padding: 2px;
    }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {

            // Hàm chính để thực hiện tìm kiếm và lọc
            function filterTable() {
                var searchText = $('#searchBox').val().toLowerCase().trim();
                var statusFilter = $('#statusFilter').val();

                // Lặp qua từng hàng trong tbody
                $('table tbody tr').each(function () {
                    var row = $(this);
                    // Lấy nội dung cột Tên Khuyến mãi (cột thứ 3, index 2)
                    var tenKhuyenMai = row.find('td:eq(2)').text().toLowerCase();
                    // Lấy nội dung cột Mã KM (cột thứ 2, index 1)
                    var maKm = row.find('td:eq(1)').text().toLowerCase();

                    // Lấy trạng thái từ thuộc tính data-status
                    var rowStatus = row.data('status');

                    // --- 1. Lọc theo văn bản (Tìm kiếm theo Tên KM hoặc Mã KM) ---
                    var textMatch = (searchText === "" || tenKhuyenMai.includes(searchText) || maKm.includes(searchText));

                    // --- 2. Lọc theo trạng thái ---
                    var statusMatch = (statusFilter === "" || rowStatus === statusFilter);

                    // --- 3. Ẩn/hiện hàng ---
                    if (textMatch && statusMatch) {
                        row.show();
                    } else {
                        row.hide();
                    }
                });
            }

            // Kích hoạt hàm lọc khi người dùng gõ vào ô tìm kiếm (tìm kiếm nhanh)
            $('#searchBox').on('keyup input', filterTable);

            // Kích hoạt hàm lọc khi người dùng thay đổi bộ lọc trạng thái
            $('#statusFilter').on('change', filterTable);

            // Chức năng nút Reset: xóa tìm kiếm, đặt lại bộ lọc và chạy lại hàm lọc
            $('#resetButton').on('click', function() {
                $('#searchBox').val('');
                $('#statusFilter').val('');
                filterTable();
            });

            // Chạy hàm lọc khi trang vừa tải xong
            filterTable();
        });
    </script>
}