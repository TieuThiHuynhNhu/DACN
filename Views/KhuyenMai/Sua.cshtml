@model DACN.Models.KhuyenMai
@{
    ViewData["Title"] = "Sửa khuyến mãi";
    var dsPhong = ViewBag.DanhSachPhong as List<DACN.Models.Phong> ?? new List<DACN.Models.Phong>();
}

<div class="container py-5">
    <h2 class="text-center fw-bold text-primary mb-4">✏️ Sửa khuyến mãi - SeaHotel</h2>

    <form asp-action="Sua" method="post" enctype="multipart/form-data" class="card p-4 shadow-sm mx-auto" style="max-width:600px;">
        <input type="hidden" asp-for="MaKhuyenMai" />

        <div class="mb-3">
            <label asp-for="TenKhuyenMai" class="form-label fw-semibold">Tên khuyến mãi</label>
            <input asp-for="TenKhuyenMai" class="form-control" />
            <span asp-validation-for="TenKhuyenMai" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Phòng áp dụng</label>
            <div class="mb-2">
                <input type="checkbox" id="selectAllRooms" />
                <label for="selectAllRooms" class="fw-bold">Chọn tất cả phòng</label>
            </div>

            <div class="border rounded p-2" style="max-height: 250px; overflow-y: auto;">
                @foreach (var phong in dsPhong)
                {
                    var isChecked = Model.PhongKhuyenMais.Any(pk => pk.MaPhong == phong.MaPhong) ? "checked" : "";
                    <div class="form-check">
                        <input type="checkbox" name="PhongIds" value="@phong.MaPhong"
                               class="form-check-input phong-checkbox" id="phong_@phong.MaPhong" @isChecked />
                        <label class="form-check-label" for="phong_@phong.MaPhong">@phong.LoaiPhong</label>
                    </div>
                }

                
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="PhanTramGiam" class="form-label fw-semibold">Phần trăm giảm giá (%)</label>
            <input asp-for="PhanTramGiam" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="PhanTramGiam" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="MoTa" class="form-label fw-semibold">Mô tả</label>
            <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
            <span asp-validation-for="MoTa" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="NgayBatDau" class="form-label fw-semibold">Ngày bắt đầu</label>
                    <input asp-for="NgayBatDau" class="form-control" type="date" />
                    <span asp-validation-for="NgayBatDau" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="NgayKetThuc" class="form-label fw-semibold">Ngày kết thúc</label>
                    <input asp-for="NgayKetThuc" class="form-control" type="date" />
                    <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="mb-3 text-center">
            <label class="form-label fw-semibold">Ảnh hiện tại</label><br />
            @if (!string.IsNullOrEmpty(Model.HinhAnh))
            {
                <img src="@Url.Content(Model.HinhAnh)" alt="Hình KM" style="width:200px; border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.2);" />
            }
            else
            {
                <span class="text-muted">Chưa có ảnh</span>
            }
        </div>

        <div class="mb-3">
            <label class="form-label fw-semibold">Thay đổi hình ảnh</label>
            <input type="file" name="HinhAnhFile" class="form-control" accept="image/*" />
        </div>

        <div class="d-flex justify-content-between flex-wrap gap-2 mt-3">
            <button type="submit" class="btn btn-warning flex-fill">💾 Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary flex-fill">↩ Quay lại</a>
        </div>

        <div asp-validation-summary="All" class="text-danger mt-2"></div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const selectAll = document.getElementById("selectAllRooms");
            const checkboxes = document.querySelectorAll(".phong-checkbox");

            selectAll.addEventListener("change", function () {
                checkboxes.forEach(cb => cb.checked = this.checked);
            });
        });
    </script>
}

<style>
    form.card input, form.card select, form.card textarea {
        transition: all 0.2s;
    }

        form.card input:focus, form.card select:focus, form.card textarea:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 6px rgba(13,110,253,0.3);
        }

    media (max-width: 576px) {
        .d-flex.flex-wrap

    {
        flex-direction: column;
    }

    }
</style>
