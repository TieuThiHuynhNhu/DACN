@model DACN.Models.ViewModel.HomeIndexViewModel

@{
    ViewData["Title"] = "Trang chủ";

    var sliders = Model.Sliders;
    var phongList = Model.PhongList;
    var dichVuList = Model.DichVuList;
    var khuyenMaiList = Model.KhuyenMais;
    var loaiPhongs = Model.LoaiPhongs;

    var today = DateTime.Now.ToString("yyyy-MM-dd");
}

<div class="header-section position-relative">
    <section class="slider-section container p-0">
        @if (sliders.Any())
        {
            <div id="sliderCarousel" class="carousel slide" data-bs-ride="carousel">

                <div class="carousel-indicators">
                    @for (int i = 0; i < sliders.Count; i++)
                    {
                        <button type="button"
                                data-bs-target="#sliderCarousel"
                                data-bs-slide-to="@i"
                                class="@(i == 0 ? "active" : "")">
                        </button>
                    }
                </div>

                <div class="carousel-inner slider-rounded-img">
                    @{
                        int index = 0;
                    }
                    @foreach (var s in sliders)
                    {
                        <div class="carousel-item @(index == 0 ? "active" : "")">
                            <img src="@Url.Content("~/hinh_ks/" + s.HinhAnh)"
                                 class="d-block w-100 slider-image"
                                 alt="Slider @(index + 1)"
                                 loading="lazy" />

                           
                        </div>
                        index++;
                    }
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#sliderCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#sliderCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        }
        else
        {
            <div class="default-slider-placeholder rounded-4">
            </div>
        }
    </section>
    <!-- Tìm kiếm-->
    <div class="search-section-overlay container">
        <div class="search-box p-4 rounded-4 shadow-lg bg-white">
            <form method="get" asp-controller="Phong" asp-action="TimKiem">
                <div class="row g-3 align-items-end">

                    <div class="col-md-3">
                        <label for="ngayDenInput" class="form-label fw-semibold">Ngày đến</label>
                        <input type="date" name="ngayDen" id="ngayDenInput" class="form-control form-control-lg rounded-pill" min="@today" required />
                    </div>

                    <div class="col-md-3">
                        <label for="ngayTraInput" class="form-label fw-semibold">Ngày trả</label>
                        <input type="date" name="ngayTra" id="ngayTraInput" class="form-control form-control-lg rounded-pill" min="@today" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Số người</label>
                        <input type="number" name="soNguoi" min="1" value="1" class="form-control form-control-lg rounded-pill" required />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Loại phòng</label>
                        <select name="loaiPhong" class="form-select form-select-lg rounded-pill">
                            <option value="">-- Tất cả --</option>
                            @foreach (var loai in loaiPhongs)
                            {
                                <option value="@loai">@loai</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary btn-lg w-100 py-2 fw-semibold rounded-pill">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>
<!-- Giao diện Popup Chat -->
<div id="chatPopup" style="display: none; position: fixed; bottom: 100px; right: 30px; width: 350px; height: 520px; background: white; border-radius: 24px; box-shadow: 0 15px 50px rgba(0,0,0,0.2); z-index: 9999; flex-direction: column; overflow: hidden; border: 1px solid #e2e8f0; transition: all 0.3s ease;">
    <!-- Header -->
    <div style="background: linear-gradient(135deg, #007bff 0%, #0056b3 100%); color: white; padding: 20px; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <h6 class="mb-0 fw-bold"><i class="bi bi-robot me-2"></i>SeaHotel AI Assistant</h6>
            <div class="flex items-center gap-1">
                <span id="chatDot" class="w-2 h-2 bg-yellow-400 rounded-full d-inline-block"></span>
                <small id="chatStatusText" class="opacity-80 text-[10px] uppercase font-bold tracking-wider">Đang khởi tạo...</small>
            </div>
        </div>
        <button onclick="toggleChat()" class="btn-close btn-close-white shadow-none"></button>
    </div>

    <!-- Chat Body -->
    <div id="chatBody" style="flex: 1; overflow-y: auto; padding: 20px; background: #f8fafc; display: flex; flex-direction: column; gap: 12px;">
        <div class="text-center my-4 opacity-50" id="initialStatus">
            <small class="bg-white px-3 py-1 rounded-pill shadow-sm border text-[10px] fw-bold uppercase tracking-tight">Hệ thống sẵn sàng hỗ trợ</small>
        </div>
    </div>

    <!-- Input -->
    <div style="padding: 15px; border-top: 1px solid #edf2f7; background: white;">
        <div id="chatErrorMsg" class="text-danger text-[10px] mb-1 font-bold text-center" style="display:none;"></div>
        <div class="input-group bg-light rounded-pill p-1 border">
            <input id="chatInput" type="text" class="form-control border-0 bg-transparent ps-3 py-2 text-sm" placeholder="Hỏi AI về giá phòng, dịch vụ..." style="box-shadow: none;" disabled>
            <button id="chatSendBtn" onclick="sendUserMessage()" class="btn btn-primary rounded-circle p-0 flex items-center justify-center shadow-md" style="width: 40px; height: 40px; min-width: 40px;" disabled>
                <i class="bi bi-send-fill" id="sendIcon"></i>
            </button>
        </div>
    </div>
</div>

<!-- Nút Chat nổi -->
<button id="chatMainBtn" onclick="toggleChat()" class="btn btn-primary shadow-2xl rounded-circle" style="position: fixed; bottom: 30px; right: 30px; width: 65px; height: 65px; z-index: 9999; font-size: 28px; background: linear-gradient(135deg, #007bff 0%, #00a8ff 100%); border: 3px solid white;">
    <i class="bi bi-chat-dots-fill"></i>
</button>

@* --- STYLE VÀ SCRIPT TÙY CHỈNH --- *@
<style>
    :root {
        --primary-color: #0077b6;
        --accent-color: #e63946;
    }

    .fw-black {
        font-weight: 900;
    }

    .slider-image {
        height: 450px;
        object-fit: cover;
        border-radius: 24px;
    }

    .search-section-overlay {
        margin-top: -50px;
        position: relative;
        z-index: 10;
    }

    .promo-card-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .promo-badge {
        position: absolute;
        top: 20px;
        right: 0;
        padding: 5px 15px;
        z-index: 5;
        border-radius: 5px 0 0 5px;
    }

    .chat-bubble-container {
        display: flex;
        flex-direction: column;
        margin-bottom: 8px;
    }

    .chat-bubble {
        padding: 10px 15px;
        border-radius: 18px;
        max-width: 85%;
        font-size: 0.85rem;
        line-height: 1.4;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .bubble-customer {
        background: #007bff;
        color: white;
        align-self: flex-end;
        border-bottom-right-radius: 2px;
    }

    .bubble-staff {
        background: white;
        color: #1e293b;
        align-self: flex-start;
        border-bottom-left-radius: 2px;
        border: 1px solid #e2e8f0;
    }

    .bubble-ai {
        background: #eff6ff;
        color: #1e40af;
        align-self: flex-start;
        border: 1px dashed #3b82f6;
        border-bottom-left-radius: 2px;
        font-style: italic;
    }
</style>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        let conversationId = null;
        let isInitializing = false;
        const chatPopup = document.getElementById("chatPopup");
        const chatBody = document.getElementById("chatBody");
        const chatInput = document.getElementById("chatInput");
        const chatSendBtn = document.getElementById("chatSendBtn");
        const chatStatusText = document.getElementById("chatStatusText");
        const chatDot = document.getElementById("chatDot");
        const chatErrorMsg = document.getElementById("chatErrorMsg");

        // 1. KẾT NỐI REAL-TIME
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveMessage", (convoId, role, sender, message, time) => {
            console.log("Realtime msg received:", { convoId, sender, message });
            // Đồng bộ kiểu dữ liệu và so sánh chính xác
            if (convoId && convoId.toString() === conversationId?.toString()) {
                appendMessageUI(sender, message, role, time);
            }
        });

        async function startSignalR() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
                chatStatusText.innerText = "Trực tuyến 24/7";
                chatDot.className = "w-2 h-2 bg-green-400 rounded-full d-inline-block";
                chatInput.disabled = false;
                chatSendBtn.disabled = false;

                // Nếu đã có ID, Join lại phòng ngay
                if (conversationId) {
                    await connection.invoke("JoinConversation", conversationId.toString());
                }
            } catch (err) {
                console.error("SignalR Start Error:", err);
                chatStatusText.innerText = "Ngoại tuyến (Đang thử lại...)";
                chatDot.className = "w-2 h-2 bg-red-500 rounded-full d-inline-block";
                setTimeout(startSignalR, 5000);
            }
        }

        startSignalR();

        // 2. LOGIC ĐÓNG/MỞ
        function toggleChat() {
            if (chatPopup.style.display === "none" || chatPopup.style.display === "") {
                chatPopup.style.display = "flex";
                if (!conversationId) initConversation();
            } else {
                chatPopup.style.display = "none";
            }
        }

        // 3. KHỞI TẠO PHIÊN CHAT (Sửa lỗi kiểm tra ID và trạng thái login)
        async function initConversation() {
            if (isInitializing) return;
            isInitializing = true;
            chatErrorMsg.style.display = "none";

            try {
                // Bước 1: Gọi API GetCurrentConversation (Đã sửa đổi trong Controller)
                // Lưu ý: Đảm bảo Controller của bạn đã có Action GetCurrentConversation trả về Json
                const res = await fetch('/Chat/GetCurrentConversation');

                if (res.status === 401 || res.status === 403 || res.redirected) {
                    throw new Error("Vui lòng đăng nhập tài khoản KHÁCH để chat.");
                }

                const data = await res.json();
                if (data.success && data.conversationId) {
                    conversationId = data.conversationId;
                    console.log("ID Hội thoại đã nhận:", conversationId);

                    // Bước 2: Join vào group SignalR để nhận tin từ AI/Nhân viên
                    if (connection.state === signalR.HubConnectionState.Connected) {
                        await connection.invoke("JoinConversation", conversationId.toString());
                    }

                    await loadHistory();
                } else {
                    throw new Error(data.message || "Tài khoản của bạn không được cấp quyền chat hoặc hệ thống đang bận.");
                }
            } catch (err) {
                console.error("InitConversation Error:", err);
                chatErrorMsg.innerText = err.message;
                chatErrorMsg.style.display = "block";
                chatBody.innerHTML = `<div class="text-center p-5 small text-muted"><i class="bi bi-lock-fill fs-3 d-block mb-2 text-danger"></i>${err.message}</div>`;
                chatInput.disabled = true;
                chatSendBtn.disabled = true;
            } finally {
                isInitializing = false;
            }
        }

        async function loadHistory() {
            if (!conversationId) return;
            try {
                const res = await fetch(`/Chat/GetMessages?conversationId=${conversationId}`);
                if (!res.ok) return;
                const msgs = await res.json();
                chatBody.innerHTML = "";
                if (msgs.length === 0) {
                    appendMessageUI("SeaHotel AI", "Xin chào! Tôi là trợ lý ảo của SeaHotel. Bạn cần hỗ trợ gì về giá phòng hay dịch vụ không?", "AI", "");
                } else {
                    msgs.forEach(m => appendMessageUI(m.guiBoiName, m.noiDung, m.guiBoiRole, m.thoiGian));
                }
            } catch (err) {
                console.error("LoadHistory Error:", err);
            }
        }

        function appendMessageUI(sender, text, role, time) {
            const isMe = (role === "KhachHang");
            const isAI = (role === "AI");

            const initStatus = document.getElementById("initialStatus");
            if (initStatus) initStatus.remove();

            const msgDiv = document.createElement("div");
            msgDiv.className = "chat-bubble-container";

            let bubbleClass = isMe ? "bubble-customer" : (isAI ? "bubble-ai" : "bubble-staff");
            msgDiv.innerHTML = `
                <div class="chat-bubble ${bubbleClass}">
                    <small class="fw-bold d-block mb-1 uppercase" style="font-size: 0.55rem; opacity: 0.8;">${isAI ? '🤖 AI ASSISTANT' : (isMe ? 'BẠN' : sender)}</small>
                    <div>${text}</div>
                    <div class="text-end mt-1" style="font-size: 0.5rem; opacity: 0.5;">${time || ''}</div>
                </div>
            `;
            chatBody.appendChild(msgDiv);
            chatBody.scrollTop = chatBody.scrollHeight;
        }

        // 4. GỬI TIN NHẮN (Gia cố để tránh mất tin)
        async function sendUserMessage() {
            const msg = chatInput.value.trim();
            if (!msg) return;

            if (!conversationId) {
                await initConversation();
                if (!conversationId) return;
            }

            const currentMsg = msg;
            chatInput.value = "";
            chatSendBtn.disabled = true;
            document.getElementById("sendIcon").className = "bi bi-hourglass-split";

            try {
                // QUAN TRỌNG: Gửi qua Controller để kích hoạt AI và lưu DB
                const response = await fetch('/Chat/SendMessage', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `conversationId=${conversationId}&message=${encodeURIComponent(currentMsg)}`
                });

                if (!response.ok) {
                    throw new Error("Không thể gửi tin nhắn lên máy chủ.");
                }
            } catch (err) {
                console.error("SendMessage Error:", err);
                chatErrorMsg.innerText = "Lỗi: " + err.message;
                chatErrorMsg.style.display = "block";
                chatInput.value = currentMsg;
            } finally {
                chatSendBtn.disabled = false;
                document.getElementById("sendIcon").className = "bi bi-send-fill";
            }
        }

        chatInput.onkeypress = (e) => { if(e.key === "Enter") sendUserMessage(); };
    </script>
}
<!-- Đặt xe -->
