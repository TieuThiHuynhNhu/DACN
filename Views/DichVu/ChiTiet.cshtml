@model DACN.Models.DichVu
@{
    ViewData["Title"] = "Chi tiết dịch vụ - SeaHotel";
}

<div class="container py-5">

    

    <div class="card shadow-lg border-0 mx-auto rounded-4 overflow-hidden service-detail-card" style="max-width:900px;">
        <div class="row g-0 align-items-stretch">

            @* --- CỘT TRÁI: HÌNH ẢNH DỊCH VỤ --- *@
            <div class="col-md-6">
                @if (!string.IsNullOrEmpty(Model.HinhAnh))
                {
                    <img src="@Model.HinhAnh" class="img-fluid w-100 h-100 rounded-start-4"
                         alt="@Model.TenDichVu" style="object-fit:cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center bg-light text-muted h-100 rounded-start-4" style="min-height: 400px;">
                        <i class="bi bi-image-fill me-2 fs-3"></i> Chưa có ảnh
                    </div>
                }
            </div>

            @* --- CỘT PHẢI: THÔNG TIN CHI TIẾT --- *@
            <div class="col-md-6 p-4 p-lg-5 d-flex flex-column justify-content-between">
                <div>
                    <h1 class="fw-bolder mb-3 text-primary">@Model.TenDichVu</h1>

                    <h5 class="fw-normal text-dark mb-4" style="line-height: 1.6;">
                        @Model.MoTa
                    </h5>

                    <hr class="my-4">

                    @* --- GIÁ DỊCH VỤ --- *@
                    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-light rounded-3 border">
                        <span class="text-dark fw-bold fs-5">GIÁ DỊCH VỤ:</span>
                        <h3 class="fw-bolder text-danger mb-0">
                            @Model.GiaDichVu?.ToString("N0") VNĐ
                        </h3>
                    </div>

                    @* --- TRẠNG THÁI --- *@
                    <p class="fw-semibold mb-3">
                        <strong class="text-dark me-2">Trạng thái:</strong>
                        @if (Model.TrangThai == "ConHoatDong")
                        {
                            <span class="badge bg-success p-2 rounded-pill">
                                <i class="bi bi-check-circle-fill me-1"></i> Còn hoạt động
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger p-2 rounded-pill">
                                <i class="bi bi-x-circle-fill me-1"></i> Ngừng cung cấp
                            </span>
                        }
                    </p>
                </div>

                @* --- NÚT HÀNH ĐỘNG --- *@
                <div class="mt-4 pt-3 border-top">
                    <a asp-action="Index" asp-controller="DichVu" class="btn btn-secondary rounded-pill fw-bold w-100">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Định nghĩa màu sắc thương hiệu */
    :root {
        --bs-primary: #0a9396; /* Xanh Navy hiện đại */
        --bs-danger: #e63946; /* Đỏ tươi cho giá */
    }

    .text-primary {
        color: var(--bs-primary) !important;
    }

    .text-danger {
        color: var(--bs-danger) !important;
    }

    /* Thiết kế Card */
    .service-detail-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .service-detail-card:hover {
            /* Bỏ hover card nâng lên, vì đây là trang chi tiết, không phải danh sách */
            transform: none;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
        }

    /* Thiết kế ảnh và góc bo */
    .rounded-start-4 {
        border-top-left-radius: 0.5rem !important;
        border-bottom-left-radius: 0.5rem !important;
        border-top-right-radius: 0 !important;
        border-bottom-right-radius: 0 !important;
    }

    /* Nút */
    .btn-secondary {
        background-color: #6c757d !important;
        border-color: #6c757d !important;
    }

        .btn-secondary:hover {
            opacity: 0.9;
        }
</style>