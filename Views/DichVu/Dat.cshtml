@model DACN.Models.ViewModel.DatDichVuViewModel
@{
    ViewData["Title"] = "Đặt dịch vụ - SeaHotel";
    var dv = ViewBag.DichVu as DACN.Models.DichVu;
    var today = DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="container py-5">
    <h2 class="text-center fw-bold mb-5 text-primary">
        <i class="bi bi-calendar-check me-2"></i> ĐẶT LỊCH DỊCH VỤ: @dv.TenDichVu
    </h2>

    <div class="row justify-content-center g-4">

        @* --- CỘT TRÁI: THÔNG TIN VÀ HÌNH ẢNH DỊCH VỤ --- *@
        <div class="col-lg-6">
            <div class="card h-100 shadow-lg border-0 rounded-4 overflow-hidden bg-white">
                @if (!string.IsNullOrEmpty(dv.HinhAnh))
                {
                    <img src="@dv.HinhAnh" class="card-img-top img-fluid" alt="Ảnh dịch vụ" style="height: 300px; object-fit: cover;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center bg-light text-muted" style="height:300px;">
                        <i class="bi bi-image-fill me-2 fs-3"></i> Chưa có ảnh
                    </div>
                }

                <div class="card-body p-4">
                    <h4 class="fw-bold text-dark mb-3">@dv.TenDichVu</h4>
                    <p class="text-muted">@dv.MoTa</p>
                    <hr class="my-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-dark fw-bold">Giá dịch vụ:</span>
                        <span class="fs-4 fw-bolder text-danger">@dv.GiaDichVu?.ToString("N0") VNĐ</span>
                    </div>
                </div>
            </div>
        </div>

        @* --- CỘT PHẢI: FORM ĐẶT LỊCH --- *@
        <div class="col-lg-6">
            <div class="card p-4 shadow-lg border-0 rounded-4 bg-light-subtle h-100">
                <h4 class="fw-bold text-primary mb-4">Nhập thông tin đặt lịch</h4>

                <form asp-action="Dat" method="post">
                    <input type="hidden" asp-for="MaDichVu" />

                    @* Ngày sử dụng (Form Floating) *@
                    <div class="form-floating mb-3">
                        <input asp-for="NgaySuDung" class="form-control rounded-3" type="date" min="@today" required placeholder="Ngày sử dụng" />
                        <label asp-for="NgaySuDung" class="fw-semibold text-primary"></label>
                        <span asp-validation-for="NgaySuDung" class="text-danger small"></span>
                    </div>

                    @* Khung giờ (Form Floating) *@
                    <div class="form-floating mb-3">
                        <select asp-for="KhungGio" class="form-select rounded-3" required>
                            <option value="08:00:00">08:00 - 09:00</option>
                            <option value="09:00:00">09:00 - 10:00</option>
                            <option value="10:00:00">10:00 - 11:00</option>
                            <option value="11:00:00">11:00 - 12:00</option>
                            <option value="14:00:00">14:00 - 15:00</option>
                            <option value="15:00:00">15:00 - 16:00</option>
                            <option value="16:00:00">16:00 - 17:00</option>
                        </select>
                        <label asp-for="KhungGio" class="fw-semibold text-primary"></label>
                        <span asp-validation-for="KhungGio" class="text-danger small"></span>
                    </div>

                    @* Số lượng *@
                    <div class="form-floating mb-3">
                        <input asp-for="SoLuong" class="form-control rounded-3" type="number" min="1" required placeholder="Số lượng" />
                        <label asp-for="SoLuong" class="fw-semibold text-primary"></label>
                        <span asp-validation-for="SoLuong" class="text-danger small"></span>
                    </div>

                    @* Ghi chú *@
                    <div class="mb-4">
                        <label asp-for="GhiChu" class="form-label fw-semibold text-primary">Ghi chú (Tùy chọn)</label>
                        <textarea asp-for="GhiChu" class="form-control rounded-3" rows="3" placeholder="Nhập ghi chú nếu có..."></textarea>
                        <span asp-validation-for="GhiChu" class="text-danger small"></span>
                    </div>

                    @* Nút hành động *@
                    <div class="d-flex justify-content-between pt-3 border-top">
                        <a asp-action="Index" asp-controller="DichVu" class="btn btn-secondary rounded-pill fw-bold">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-warning rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-send-fill"></i> XÁC NHẬN ĐẶT LỊCH
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    /* Định nghĩa màu sắc thương hiệu */
    :root {
        --bs-primary: #0a9396; /* Xanh Navy hiện đại */
        --bs-warning: #ffb703; /* Vàng sáng cho nút đặt lịch */
        --bs-danger: #e63946; /* Đỏ tươi cho giá */
    }

    .text-primary {
        color: var(--bs-primary) !important;
    }

    .text-danger {
        color: var(--bs-danger) !important;
    }

    /* Cải thiện Form Control */
    .form-control, .form-select {
        border-radius: 0.5rem;
        height: calc(3.5rem + 2px); /* Dành cho Form Floating */
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--bs-primary);
            box-shadow: 0 0 0 0.25rem rgba(10, 147, 150, 0.25);
        }

    /* Thiết kế nút */
    .btn-warning {
        background-color: var(--bs-warning) !important;
        color: #333 !important;
        transition: transform 0.2s;
    }

        .btn-warning:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(255, 183, 3, 0.4) !important;
        }

    /* Nền nhẹ cho form */
    .bg-light-subtle {
        background-color: #f8f9fa !important;
    }
</style>