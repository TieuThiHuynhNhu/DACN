@model DACN.Models.ViewModel.XacNhanDichVuViewModel
@{
    ViewData["Title"] = "Xác nhận đặt dịch vụ - SeaHotel";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 mx-auto rounded-4 overflow-hidden" style="max-width:900px;">

        @* --- HEADER XÁC NHẬN --- *@
        <div class="card-header text-white text-center fw-bold p-3 bg-primary rounded-top-4">
            <h4 class="mb-0">
                <i class="bi bi-check-circle-fill me-2"></i> ĐẶT DỊCH VỤ THÀNH CÔNG!
            </h4>
        </div>

        <div class="card-body p-0">
            <div class="row g-0">

                @* --- CỘT TRÁI: HÌNH ẢNH DỊCH VỤ --- *@
                <div class="col-md-5">
                    @if (!string.IsNullOrEmpty(Model.DichVu.HinhAnh))
                    {
                        <img src="@Model.DichVu.HinhAnh" class="img-fluid h-100" alt="Ảnh dịch vụ" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light text-muted h-100" style="min-height: 250px;">
                            <i class="bi bi-image-fill me-2 fs-3"></i> Không có ảnh
                        </div>
                    }
                </div>

                @* --- CỘT PHẢI: CHI TIẾT XÁC NHẬN --- *@
                <div class="col-md-7 p-4 p-md-5">
                    <h3 class="fw-bold mb-4 text-primary">@Model.DichVu.TenDichVu</h3>

                    <div class="list-group list-group-flush mb-4">
                        <div class="list-group-item d-flex justify-content-between">
                            <strong>Khách hàng:</strong> <span class="text-dark">@Model.KhachHang.HoTen</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <strong>Ngày sử dụng:</strong> <span class="text-dark fw-medium">@Model.NgaySuDung.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <strong>Khung giờ:</strong> <span class="text-dark fw-medium">@Model.KhungGio.ToString(@"hh\:mm") - @(Model.KhungGio.Add(TimeSpan.FromHours(1)).ToString(@"hh\:mm"))</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between">
                            <strong>Số lượng:</strong> <span class="text-dark">@Model.SoLuong</span>
                        </div>
                        <div class="list-group-item d-flex justify-content-between bg-light">
                            <strong>Thành tiền:</strong> <span class="fs-5 fw-bolder text-danger">@Model.ThanhTien.ToString("N0") VNĐ</span>
                        </div>
                    </div>

                    <p class="text-muted small">
                        <strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có ghi chú." : Model.GhiChu)
                    </p>

                    <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                        <a asp-action="Index" asp-controller="DichVu" class="btn btn-outline-primary rounded-pill fw-bold">
                            <i class="bi bi-arrow-left"></i> Quay về dịch vụ
                        </a>
                        <a asp-action="LichSuDatDichVu" asp-controller="DatDichVu" class="btn btn-success rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-history"></i> Xem lịch sử đặt
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    /* Định nghĩa màu sắc thương hiệu */
    :root {
        --bs-primary: #0a9396; /* Xanh Navy hiện đại */
        --bs-success: #28a745;
        --bs-danger: #e63946;
    }

    .bg-primary {
        background-color: var(--bs-primary) !important;
    }

    .text-primary {
        color: var(--bs-primary) !important;
    }

    .text-danger {
        color: var(--bs-danger) !important;
    }

    /* Thiết kế Card */
    .card {
        border: none;
    }

    /* Thiết kế danh sách chi tiết (List Group) */
    .list-group-item {
        padding: 0.75rem 1rem;
        border-color: #eee;
    }

        .list-group-item:last-child {
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
        }

        .list-group-item.bg-light {
            background-color: #f8f9fa !important;
            font-size: 1.1rem;
        }

    /* Hiệu ứng nút */
    .btn-success {
        background-color: var(--bs-success) !important;
        border-color: var(--bs-success) !important;
        transition: transform 0.2s;
    }

        .btn-success:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 8px rgba(40, 167, 69, 0.4) !important;
        }
</style>