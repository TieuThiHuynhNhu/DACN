@model DACN.Models.DatPhong

@{
    ViewData["Title"] = "Xác nhận đặt phòng";
    var phong = ViewBag.Phong as DACN.Models.Phong;
    var khach = ViewBag.KhachHang as DACN.Models.KhachHang;
}

<div class="container py-5">
    <h2 class="text-center fw-bold mb-5 text-primary">
        <i class="bi bi-shield-check me-2"></i> XÁC NHẬN VÀ THANH TOÁN
    </h2>

    <div class="row justify-content-center">
        <div class="col-lg-8">

            @* --- 1. THÔNG TIN ĐẶT PHÒNG (Card Tổng quan hiện đại) --- *@
            <div class="card p-4 mb-5 shadow-lg border-0 rounded-4" style="background-color:#e0f7fa;">
                <h4 class="fw-bold text-center mb-4 text-dark">Chi tiết giao dịch</h4>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <p class="mb-1 text-muted small">Khách hàng</p>
                        <h5 class="fw-bold text-primary">@khach?.HoTen</h5>
                    </div>
                    <div class="col-md-6 mb-3">
                        <p class="mb-1 text-muted small">Phòng đặt</p>
                        <h5 class="fw-bold text-primary">@phong?.LoaiPhong</h5>
                    </div>
                    <div class="col-md-6 mb-3">
                        <p class="mb-1 text-muted small">Ngày nhận phòng</p>
                        <h5 class="fw-bold text-dark">@Model.NgayNhan?.ToString("dd/MM/yyyy")</h5>
                    </div>
                    <div class="col-md-6 mb-3">
                        <p class="mb-1 text-muted small">Ngày trả phòng</p>
                        <h5 class="fw-bold text-dark">@Model.NgayTra?.ToString("dd/MM/yyyy")</h5>
                    </div>
                </div>
                <hr class="my-3 border-secondary" />
                <div class="text-center">
                    <p class="mb-1 fw-bold fs-6">TỔNG SỐ TIỀN CẦN THANH TOÁN</p>
                    <h3 class="fw-bolder text-danger display-6">
                        @Model.TongTien.ToString("N0") VNĐ
                    </h3>
                </div>
            </div>

            @* --- 2. PHƯƠNG THỨC THANH TOÁN --- *@
            <h4 class="text-center fw-bold mb-4 text-dark">Chọn phương thức thanh toán</h4>

            <div class="row g-4 mb-5">

                @* VNPay *@
                <div class="col-md-6">
                    <form asp-controller="Payment" asp-action="CreatePaymentUrlVnpay" method="post" class="h-100">
                        <input type="hidden" name="OrderId" value="@ViewBag.PaymentModel.OrderId" />
                        <input type="hidden" name="Amount" value="@ViewBag.PaymentModel.Amount" />
                        <input type="hidden" name="OrderDescription" value="@ViewBag.PaymentModel.OrderDescription" />
                        <input type="hidden" name="Name" value="@ViewBag.PaymentModel.Name" />
                        <input type="hidden" name="OrderType" value="@ViewBag.PaymentModel.OrderType" />
                        <button type="submit" class="btn btn-block btn-lg p-4 w-100 shadow-sm border-0 rounded-3 payment-btn vnpay-bg">
                            <i class="bi bi-credit-card-fill me-2 fs-4"></i>
                            <span class="fs-5 fw-bold">THANH TOÁN VNPay</span>
                        </button>
                    </form>
                </div>

                @* MoMo *@
                <div class="col-md-6">
                    <form method="POST" asp-action="CreatePaymentMoMo" asp-controller="Payment" class="h-100">
                        <input type="hidden" name="maDatPhong" value="@Model.MaDatPhong" />
                        <input type="hidden" name="FullName" value="SeaHotel" />
                        <input type="hidden" name="Amount" value="@Model.TongTien" />
                        <input type="hidden" name="OrderInfo" value="Thanh toán đặt phòng qua Momo tại SeaHotel" />
                        <input type="hidden" name="OrderId" value="DP_@Model.MaDatPhong" />
                        <button class="btn btn-block btn-lg p-4 w-100 shadow-sm border-0 rounded-3 payment-btn momo-bg">
                            <i class="bi bi-qr-code-scan me-2 fs-4"></i>
                            <span class="fs-5 fw-bold">THANH TOÁN MoMo</span>
                        </button>
                    </form>
                </div>
            </div>

            @* --- 3. THANH TOÁN SAU (Lựa chọn phụ) --- *@
            <div class="alert alert-light text-center border-dashed rounded-3 p-4 mb-4" role="alert">
                <p class="mb-3 text-muted">Hoặc bạn có thể chọn hình thức thanh toán tại quầy khi đến nhận phòng:</p>

                <form asp-controller="DatPhong" asp-action="ChuyenSangThanhToanSau" method="post" class="w-100">
                    <input type="hidden" name="maDatPhong" value="@Model.MaDatPhong" />
                    <button type="submit" class="btn btn-outline-secondary w-100 btn-lg rounded-pill fw-bold"
                            onclick="return confirm('Xác nhận chuyển sang Thanh toán tại quầy? Phòng của bạn sẽ được giữ và bạn cần thanh toán khi nhận phòng.')">
                        <i class="bi bi-wallet2 me-2"></i> THANH TOÁN TẠI QUẦY (THANH TOÁN SAU)
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

<style>
    /* Định nghĩa màu sắc thương hiệu */
    :root {
        --bs-primary: #0a9396;
        --bs-danger: #e63946;
        --vnpay-color: #0077b6;
        --momo-color: #d82b88; /* Màu hồng Momo */
    }

    /* Cấu trúc chung */
    .text-primary {
        color: var(--bs-primary) !important;
    }

    .text-danger {
        color: var(--bs-danger) !important;
    }

    /* Nút Thanh toán Trực tuyến */
    .payment-btn {
        color: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        height: 100%;
    }

        .payment-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.2);
            color: white;
        }

    /* Màu nền cụ thể */
    .vnpay-bg {
        background-color: var(--vnpay-color);
    }

    .momo-bg {
        background-color: var(--momo-color);
    }

        .momo-bg:hover {
            background-color: #c7267a; /* Tối màu hơn khi hover */
        }

    /* Viền gạch đứt cho phần thanh toán sau */
    .border-dashed {
        border: 2px dashed #ced4da;
    }
</style>