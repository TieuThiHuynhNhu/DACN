@model DACN.Models.DatDichVu

@{
    ViewData["Title"] = "Chi Tiết Đặt Dịch Vụ";
    var tongTien = (decimal)ViewData["TongTien"];
}

<div class="container my-4">
    <h2 class="mb-5 text-center" style="color:#005f73;"><i class="bi bi-file-earmark-text-fill"></i> Hóa đơn Dịch Vụ #@Model.MaDatDichVu</h2>

    <div class="card shadow-lg mx-auto" style="max-width: 700px;">
        <div class="card-header bg-primary text-white text-center">
            <h4 class="mb-0">Thông tin chi tiết dịch vụ đã đặt</h4>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Mã đơn đặt:</div>
                <div class="col-sm-8"><strong>#@Model.MaDatDichVu</strong></div>
            </div>

            @if (Model.KhachHang != null)
            {
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Khách hàng:</div>
                    <div class="col-sm-8"><strong>@Model.KhachHang.HoTen</strong></div>
                </div>
            }

            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Dịch vụ:</div>
                <div class="col-sm-8"><strong class="text-primary">@Model.DichVu?.TenDichVu</strong></div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Ngày sử dụng:</div>
                <div class="col-sm-8">@Model.NgaySuDung?.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Khung giờ:</div>
                <div class="col-sm-8">
                    @Model.KhungGio?.ToString(@"hh\:mm") - @(Model.KhungGio?.Add(TimeSpan.FromHours(1)).ToString(@"hh\:mm"))
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Giá dịch vụ:</div>
                <div class="col-sm-8">@((Model.DichVu?.GiaDichVu ?? 0).ToString("N0")) VNĐ</div>
            </div>

            <div class="row mb-3">
                <div class="col-sm-4 text-muted">Trạng thái:</div>
                <div class="col-sm-8">
                    <span class="badge @(Model.TrangThai == "Đặt thành công" ? "bg-success" : Model.TrangThai == "Chờ thanh toán" ? "bg-warning text-dark" : "bg-secondary")">@Model.TrangThai</span>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.GhiChu))
            {
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted">Ghi chú:</div>
                    <div class="col-sm-8"><em>@Model.GhiChu</em></div>
                </div>
            }

            <hr class="my-4" />

            <div class="row">
                <div class="col-sm-6">
                    <h5 class="text-muted mb-0">TỔNG TIỀN CẦN THANH TOÁN:</h5>
                </div>
                <div class="col-sm-6 text-end">
                    <h4 class="text-danger mb-0">@tongTien.ToString("N0") VNĐ</h4>
                </div>
            </div>
        </div>
        <a href="@Url.Action("InHoaDonDichVu", new { id = Model.MaDatDichVu })" target="_blank" class="btn btn-success">
            <i class="bi bi-printer-fill"></i> In Hóa Đơn
        </a>
        <div class="card-footer text-center">
            <a href="@Url.Action("LichSuDatDichVu")" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại lịch sử</a>
            @if (Model.TrangThai == "Chờ thanh toán")
            {
                <a href="#" class="btn btn-success"><i class="bi bi-credit-card-fill"></i> Thanh toán ngay</a>
            }
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    .card {
        border: none;
    }

    .card-header {
        border-radius: 0.35rem 0.35rem 0 0 !important;
    }
</style>