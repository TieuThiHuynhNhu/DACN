@model DACN.Models.DatDichVu

@{
    // Sử dụng Layout trống để loại bỏ header/footer khi in
    Layout = null;
    ViewData["Title"] = "In Hóa đơn dịch vụ";
    decimal tongTien = (decimal)ViewData["TongTien"];
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Hóa Đơn Dịch Vụ #@Model.MaDatDichVu</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/5.0.0-alpha1/css/bootstrap.min.css" integrity="sha384-r4NyP46KrjDleawBgD5tp8Y7UzmLA05oM1iAEQ17CSuDqnUK2+k9luXQOfXJCJ4I" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        /* CSS dành cho trang in */
        body {
            font-family: Arial, sans-serif;
            padding: 30px;
        }

        .invoice-box {
            max-width: 800px;
            margin: auto;
            padding: 30px;
            border: 1px solid #eee;
            box-shadow: 0 0 10px rgba(0, 0, 0, .15);
            font-size: 16px;
            line-height: 24px;
            color: #555;
        }

        .total-amount {
            font-size: 1.5rem;
            font-weight: bold;
            color: #dc3545; /* Màu đỏ */
        }
        /* Ẩn nút in khi in thực tế */
        @@media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>
<body onload="window.print()">
    <div class="invoice-box">
        <h2 class="text-center mb-4 text-primary">HÓA ĐƠN DỊCH VỤ - SEA HOTEL</h2>

        <div class="row mb-3">
            <div class="col-6">
                <strong>Mã đơn đặt:</strong> #@Model.MaDatDichVu
            </div>
            <div class="col-6 text-end">
                <strong>Ngày in:</strong> @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>

        <hr />

        <div class="card p-3 mb-4">
            <h5 class="text-info mb-3"><i class="bi bi-person-fill"></i> Thông tin khách hàng</h5>
            <p><strong>Họ tên:</strong> @Model.KhachHang?.HoTen</p>
            <p><strong>Email:</strong> @Model.KhachHang?.Email</p>
        </div>

        <div class="card p-3 mb-4">
            <h5 class="text-info mb-3"><i class="bi bi-tag-fill"></i> Chi tiết dịch vụ</h5>
            <table class="table table-bordered">
                <thead>
                    <tr class="table-primary">
                        <th>Dịch vụ</th>
                        <th class="text-center">Ngày sử dụng</th>
                        <th class="text-center">Khung giờ</th>
                        <th class="text-end">Đơn giá</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.DichVu?.TenDichVu</td>
                        <td class="text-center">@Model.NgaySuDung?.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">@Model.KhungGio?.ToString(@"hh\:mm") - @(Model.KhungGio?.Add(TimeSpan.FromHours(1)).ToString(@"hh\:mm"))</td>
                        <td class="text-end">@((Model.DichVu?.GiaDichVu ?? 0).ToString("N0")) VNĐ</td>
                    </tr>
                </tbody>
            </table>
            <p><strong>Ghi chú:</strong> @(string.IsNullOrEmpty(Model.GhiChu) ? "Không có" : Model.GhiChu)</p>
            <p><strong>Trạng thái:</strong> <span class="badge bg-success">@Model.TrangThai</span></p>
        </div>

        <div class="text-end mt-4">
            <h4 class="mb-0">TỔNG TIỀN CẦN THANH TOÁN</h4>
            <span class="total-amount">@tongTien.ToString("N0") VNĐ</span>
        </div>

        <div class="text-center mt-5 no-print">
            <button class="btn btn-secondary" onclick="window.close();">
                <i class="bi bi-x-circle-fill"></i> Đóng cửa sổ
            </button>
        </div>
    </div>
</body>
</html>