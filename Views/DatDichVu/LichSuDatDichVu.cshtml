@model List<DACN.Models.DatDichVu>

@{
    ViewData["Title"] = "Lịch sử đặt dịch vụ";
}
@if (Model != null)
{
    @foreach (var item in Model)
    {
        @if (item.DichVu == null)
        {
            <div class="alert alert-danger">
                <strong>LỖI DỮ LIỆU:</strong> Lịch đặt dịch vụ #@item.MaDatDichVu không tìm thấy thông tin Dịch Vụ!
                (Có thể do thiếu .Include(d => d.DichVu) trong Controller)
            </div>
            break; // Dừng lại để bạn thấy lỗi
        }
    }
}
<div class="container my-4">
    

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center" role="alert">
            <i class="bi bi-info-circle-fill"></i> Bạn chưa đặt lịch dịch vụ nào.
            <p class="mt-2"><a href="@Url.Action("Index", "DatDichVu")" class="btn btn-primary">Đặt dịch vụ ngay</a></p>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-lg-6 col-md-12 mb-4">
                    <div class="card shadow-sm h-100">
                        @{
                            // 1. Xác định class màu cho Card Header (Đã sửa để khớp với các trạng thái Databse)
                            string headerClass = "bg-secondary text-white";
                            if (item.TrangThai == "Đã thanh toán" || item.TrangThai == "DatThanhCong")
                            {
                                headerClass = "bg-primary text-white"; // Dùng màu xanh dương primary cho Đã thanh toán (giống Đặt phòng)
                            }
                            else if (item.TrangThai == "Chờ thanh toán" || item.TrangThai == "Đã đặt")
                            {
                                headerClass = "bg-warning text-dark";
                            }

                            // 2. Xác định class màu cho Badge
                            string badgeClass = "bg-secondary";
                            if (item.TrangThai == "Đã thanh toán" || item.TrangThai == "DatThanhCong")
                            {
                                badgeClass = "bg-success";
                            }
                            else if (item.TrangThai == "Chờ thanh toán" || item.TrangThai == "Đã đặt")
                            {
                                badgeClass = "bg-warning text-dark";
                            }
                        }

                        <div class="card-header @headerClass">
                            <h5 class="mb-0">
                                @item.DichVu?.TenDichVu
                            </h5>
                        </div>

                        <div class="card-body">
                            <div class="row">
                                <div class="col-sm-5 mb-3 mb-sm-0">
                                    @if (!string.IsNullOrEmpty(item.DichVu?.HinhAnh))
                                    {
                                        <img src="@item.DichVu.HinhAnh" class="img-fluid rounded" alt="@item.DichVu.TenDichVu" style="height: 150px; object-fit: cover; width: 100%;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light text-center p-5 rounded" style="height: 150px;">
                                            <i class="bi bi-image" style="font-size: 2rem;"></i><br />
                                            Không có ảnh
                                        </div>
                                    }
                                </div>

                                <div class="col-sm-7">
                                    <p class="mb-1"><strong>Ngày sử dụng:</strong> @item.NgaySuDung?.ToString("dd/MM/yyyy")</p>
                                    <p class="mb-1"><strong>Khung giờ:</strong> @item.KhungGio?.ToString(@"hh\:mm") - @(item.KhungGio?.Add(TimeSpan.FromHours(1)).ToString(@"hh\:mm"))</p>

                                    <p class="mb-2">
                                        <strong>Trạng thái:</strong>
                                        <span class="badge @badgeClass">@item.TrangThai</span>
                                    </p>

                                    @if (ViewData["IsAdmin"] != null && (bool)ViewData["IsAdmin"])
                                    {
                                        <p class="mb-2"><strong>Khách hàng:</strong> @item.KhachHang?.HoTen</p>
                                    }

                                    <p class="mb-3"><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@((item.DichVu?.GiaDichVu ?? 0).ToString("N0")) VNĐ</span></p>

                                    <hr class="my-2" />

                                    <a href="@Url.Action("ChiTietDatDichVu", new { id = item.MaDatDichVu })" class="btn btn-info w-100 btn-sm mt-1">
                                        <i class="bi bi-eye-fill"></i> Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    /* CSS được giữ nguyên để styling card */
    .card-header {
        border-bottom: 0;
        padding: 0.75rem 1.25rem;
    }

        .card-header h5 {
            font-size: 1.25rem;
        }

    .badge {
        font-size: 0.9em;
        padding: 0.4em 0.6em;
    }
</style>