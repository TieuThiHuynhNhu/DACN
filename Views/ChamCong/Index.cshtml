@{
    ViewData["Title"] = "Chấm công";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <h2 class="text-center fw-bold text-uppercase mb-5" style="color:#0077b6;">
                <i class="bi bi-clock-history me-3"></i> Chấm Công Bằng Nhận Diện Khuôn Mặt
            </h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-x-octagon-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow-lg border-0 p-4" style="border-top: 6px solid #00b4d8; border-radius: 12px;">
                <div class="card-body">

                    <h4 class="card-title fw-bold text-center mb-4 text-primary">
                        Vui lòng nhìn thẳng vào Camera
                    </h4>

                    <div class="d-flex justify-content-center mb-4">
                        <div class="camera-container border border-primary border-3 rounded-3 overflow-hidden shadow-sm">
                            <video id="camera" width="320" height="240" autoplay style="display: block;"></video>

                            <canvas id="snapshot" width="320" height="240" style="display:none;"></canvas>
                        </div>
                    </div>

                    <form asp-action="CheckIn" asp-controller="ChamCong" method="post" class="text-center">
                        <input type="hidden" id="anhKhuonMat" name="anhKhuonMatBase64" />

                        <button type="button" class="btn btn-info btn-lg px-4 shadow-sm me-3" onclick="takeSnapshot()">
                            <i class="bi bi-camera-fill me-2"></i> Chụp ảnh
                        </button>

                        <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm">
                            <i class="bi bi-box-arrow-in-right me-2"></i> Check-in
                        </button>
                    </form>

                    <form asp-action="CheckOut" asp-controller="ChamCong" method="post" class="mt-3 text-center">
                        <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">
                            <i class="bi bi-box-arrow-left me-2"></i> Check-out
                        </button>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a class="btn btn-outline-primary btn-lg px-5" asp-action="LichSuNhanVien" asp-controller="ChamCong">
                    <i class="bi bi-calendar-check me-2"></i> Xem lịch sử chấm công
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        const video = document.getElementById('camera');
        const canvas = document.getElementById('snapshot');
        const context = canvas.getContext('2d');

        // Bật camera
        if (navigator.mediaDevices && navigator.mediaDevices.getUserMedia) {
            navigator.mediaDevices.getUserMedia({ video: true })
                .then(stream => { video.srcObject = stream; })
                .catch(err => {
                    console.error("Lỗi camera: ", err);
                    // Cải thiện thông báo lỗi cho người dùng
                    document.querySelector('.camera-container').innerHTML =
                        '<p class="text-danger p-3 fw-bold">❌ Lỗi: Không thể truy cập Camera. Vui lòng kiểm tra quyền truy cập!</p>';
                });
        } else {
             document.querySelector('.camera-container').innerHTML =
                '<p class="text-danger p-3 fw-bold">❌ Lỗi: Trình duyệt không hỗ trợ Camera.</p>';
        }

        // Chụp ảnh
        function takeSnapshot() {
            context.drawImage(video, 0, 0, canvas.width, canvas.height);
            let dataUrl = canvas.toDataURL("image/png"); // base64
            document.getElementById("anhKhuonMat").value = dataUrl;

            // Thay thế alert bằng thông báo trực quan hơn (Ví dụ: thay đổi viền camera)
            const cameraContainer = document.querySelector('.camera-container');
            cameraContainer.classList.add('border-success');
            cameraContainer.classList.remove('border-primary');

            alert("📷 Ảnh đã được chụp thành công! Vui lòng bấm Check-in/Check-out để lưu.");

            // Sau 2 giây, chuyển viền lại
            setTimeout(() => {
                cameraContainer.classList.remove('border-success');
                cameraContainer.classList.add('border-primary');
            }, 2000);
        }
    </script>
}