ats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE DatXe_New (
    MaDatXe INTEGER PRIMARY KEY AUTOINCREMENT,
    TenKhachHang TEXT NOT NULL,
    DiaDiemDi TEXT NOT NULL,
    DiaDiemDen TEXT NOT NULL,
    KhoangCach DECIMAL(10,2) NOT NULL,
    GiaTien DECIMAL(18,2) NOT NULL,
    LoaiXe TEXT,
    NgayDat TEXT NOT NULL,
    GhiChu TEXT,
    MaKhachHang INTEGER,
    FOREIGN KEY(MaKhachHang) REFERENCES KhachHang(MaKhachHang)
);
INSERT INTO DatXe_New (MaDatXe, TenKhachHang, DiaDiemDi, DiaDiemDen, KhoangCach, GiaTien, LoaiXe, NgayDat, GhiChu, MaKhachHang)
SELECT MaDatXe, TenKhachHang, DiaDiemDi, DiaDiemDen, KhoangCach, GiaTien, LoaiXe, NgayDat, GhiChu, MaKhachHang
FROM DatXe;
DROP TABLE DatXe;
ALTER TABLE DatXe_New RENAME TO DatXe;

</sql><current_tab id="0"/></tab_sql></sqlb_project>
